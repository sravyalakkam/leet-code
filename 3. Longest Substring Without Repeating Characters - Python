class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        maxCount = 0
        substringSet = set()
        left = 0
        for right,c in enumerate(s):
            while s[right] in substringSet:
                substringSet.remove(s[left])
                left+=1
            substringSet.add(s[right])
            maxCount = max(maxCount,(right-left)+1)
        return maxCount
